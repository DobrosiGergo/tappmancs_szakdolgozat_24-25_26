{
    "name": "tappmancs",
    "private": true,
    "workspaces": [
        "app",
        "app-e2e"
    ],
    "scripts": {
        "dev": "npm --workspace app run dev",
        "build": "npm --workspace app run build",
        "test": "npm --workspace app run test:all",
        "test:feature": "npm --workspace app run test:feature",
        "test:unit": "npm --workspace app run test:unit",
        "test:e2e": "npm --workspace app-e2e run test",
        "lint": "npm --workspace app run lint:pint"
    }
}
